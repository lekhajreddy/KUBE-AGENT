# KubeMind AI — Environment Variables
# Copy this file to .env and fill in your values.

# ── Database ──────────────────────────────────────────────────────────────
DB_ENABLED=True
# Ensure this matches docker-compose or your cloud DB
DATABASE_URL=postgresql+asyncpg://kubemind:kubemind@localhost:5432/kubemind

# ── Redis (Event Bus / Caching) ───────────────────────────────────────────
REDIS_ENABLED=True
REDIS_URL=redis://localhost:6379/0

# ── Kafka (Optional Event Bus) ────────────────────────────────────────────
# Uncomment to use Kafka instead of/alongside Redis
# KAFKA_BROKERS=localhost:9092

# ── Ollama AI (optional) ──────────────────────────────────────────────────────
# Run: ollama pull llama3.2
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_ENABLED=true

# ── Kubernetes (optional) ─────────────────────────────────────────────────────
# Set K8S_SIMULATION_MODE=false when a real cluster is available
K8S_SIMULATION_MODE=false
K8S_IN_CLUSTER=false

# ── Prometheus ────────────────────────────────────────────────────────────────
PROMETHEUS_URL=http://localhost:9090

# ── App ────────────────────────────────────────────────────────────────────────
DEBUG=false
HOST=0.0.0.0
PORT=8000
